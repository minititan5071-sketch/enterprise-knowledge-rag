APP_NAME=Enterprise Knowledge RAG
ENVIRONMENT=production
AUTO_CREATE_TABLES=false

DATABASE_URL=postgresql+psycopg://rag:rag@postgres:5432/rag
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag

JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=60

DATA_DIR=data
UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE_MB=50

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=false

VECTOR_STORE=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=enterprise_knowledge_chunks

EMBEDDING_PROVIDER=local
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=384

LLM_PROVIDER=local
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=45

RAG_TOP_K=8
RAG_MIN_SCORE=0
CHUNK_SIZE_CHARS=1200
CHUNK_OVERLAP_CHARS=180

OTEL_ENABLED=true
OTEL_SERVICE_NAME=enterprise-knowledge-rag-api
OTEL_EXPORTER_OTLP_ENDPOINT=

# Used by Streamlit when running outside Docker.
BACKEND_URL=http://backend:8000

# Kept for backend settings compatibility if a reverse proxy or deployment platform needs it.
FRONTEND_BACKEND_URL=http://backend:8000
