APP_NAME=Enterprise Knowledge RAG
ENVIRONMENT=local-persistent
AUTO_CREATE_TABLES=true

POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
DATABASE_URL=postgresql+psycopg://rag:rag@postgres:5432/rag

JWT_SECRET_KEY=replace-with-a-long-random-local-development-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

DATA_DIR=data
UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE_MB=50

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=false

VECTOR_STORE=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=enterprise_knowledge_chunks

EMBEDDING_PROVIDER=local
EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=local-hashing-embedding
EMBEDDING_DIMENSION=384

LLM_PROVIDER=openai-compatible
LLM_BASE_URL=http://host.docker.internal:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=qwen/qwen3.6-27b
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=240

RAG_TOP_K=8
RAG_MIN_SCORE=0
CHUNK_SIZE_CHARS=1200
CHUNK_OVERLAP_CHARS=180

OTEL_ENABLED=false
OTEL_SERVICE_NAME=enterprise-knowledge-rag-api-local
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

BACKEND_URL=http://backend:8000
FRONTEND_BACKEND_URL=http://backend:8000
